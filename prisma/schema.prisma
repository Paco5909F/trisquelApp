generator client {
  provider = "prisma-client-js"
  engineType = "library"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
}

enum UserRole {    
  ADMIN
  ENCARGADO
  MAQUINISTA
  TRANSPORTISTA
  LECTOR
  // Legacy roles (kept for DB compatibility)
  admin
  operario
  cliente
  @@map("user_role")
}

model Empresa {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre      String
  cuit        String?
  direccion   String?
  logo_url    String? // URL to Supabase Storage
  email       String?
  telefono    String?
  
  
  usuarios    Usuario[]
  miembros    Miembro[] // New many-to-many relation
  clientes    Cliente[]
  establecimientos Establecimiento[]
  silos       Silo[]
  movimientos MovimientoStock[]
  lotes       Lote[]
  servicios   Servicio[]
  ordenes     OrdenTrabajo[]
  facturas    Factura[]
  campanas    Campana[]
  presupuestos Presupuesto[]
  cartas_porte CartaPorte[]
  insumos      Insumo[]

  // Billing Fields
  plan_status     String   @default("FREE") // FREE, PRO, CANCELLED
  subscription_id String?  // Mercado Pago Preapproval ID
  trial_ends_at   DateTime? @db.Timestamptz

  // Invite System
  shared_invite_code String? @unique // Code for auto-joining

  created_at  DateTime @default(now()) @db.Timestamptz
  
  @@map("empresas")
}

enum OrderStatus {
  pendiente
  en_proceso
  completada
  cancelada
  facturada
  @@map("order_status")
}

model Usuario {
  id                String   @id @db.Uuid
  nombre            String
  email             String?  @unique
  rol               UserRole @default(LECTOR) // Keeps global role for now, but Miembro.rol takes precedence in context
  
  // Legacy single-tenant relation (deprecated but kept for migration)
  empresa_id        String?  @db.Uuid
  empresa           Empresa? @relation(fields: [empresa_id], references: [id])
  
  // New multi-tenant relations
  active_empresa_id String?  @db.Uuid // Stores the last accessed company
  miembros          Miembro[]

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @default(now()) @db.Timestamptz

  @@map("usuarios")
}

model Miembro {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id String   @db.Uuid
  usuario    Usuario  @relation(fields: [usuario_id], references: [id])
  empresa_id String   @db.Uuid
  empresa    Empresa  @relation(fields: [empresa_id], references: [id])
  rol        UserRole @default(LECTOR)
  
  created_at DateTime @default(now()) @db.Timestamptz

  @@unique([usuario_id, empresa_id])
  @@map("miembros")
}

model Invitation {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String
  rol        UserRole @default(LECTOR)
  empresa_id String   @db.Uuid
  token      String   @unique @default(dbgenerated("uuid_generate_v4()")) // Using UUID as token
  status     String   @default("PENDING") // PENDING, ACCEPTED
  expires_at DateTime
  created_at DateTime @default(now()) @db.Timestamptz
  
  @@map("invitations")
}

model Cliente {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  razon_social  String
  empresa_id    String?   @db.Uuid
  empresa       Empresa?  @relation(fields: [empresa_id], references: [id])
  cuit          String
  condicion_iva String
  email         String?
  telefono      String?
  persona_contacto String?
  tipo_cliente  String?   // Productor, Acopio, etc.
  localidad     String?
  provincia     String?
  observaciones String?
  localidad_id  String?   @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @default(now()) @db.Timestamptz
  deleted_at    DateTime? @db.Timestamptz

  establecimientos Establecimiento[]
  ordenes          OrdenTrabajo[]
  presupuestos     Presupuesto[]
  cartas_porte     CartaPorte[]

  @@map("clientes")
  @@index([empresa_id])
  @@unique([cuit, empresa_id]) // CUIT unique per company
}

model Establecimiento {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre     String
  empresa_id String?   @db.Uuid
  empresa    Empresa?  @relation(fields: [empresa_id], references: [id])
  cliente_id String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  modalidad  String    @default("PROPIO") // PROPIO, ALQUILADO

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  lotes   Lote[]
  silos   Silo[]

  @@map("establecimientos")
  @@index([empresa_id])
  @@index([cliente_id])
}

model Silo {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre             String
  tipo               String    // FIJO, SILOBOLSA, CELDA, PLANTA
  empresa_id         String?   @db.Uuid
  empresa            Empresa?  @relation(fields: [empresa_id], references: [id])
  capacidad_max      Decimal   @db.Decimal(12, 2)
  stock_actual       Decimal   @db.Decimal(12, 2) @default(0)
  humedad            Decimal?  @db.Decimal(5, 2)
  grano              String?   // SOJA, MAIZ, TRIGO, etc.
  estado             String    @default("DISPONIBLE") // DISPONIBLE, EN_USO, LLENO, EN_DESCARGA, CERRADO
  
  establecimiento_id String    @db.Uuid
  campana_id         String?   @db.Uuid
  
  active             Boolean   @default(true)
  created_at         DateTime  @default(now()) @db.Timestamptz
  
  establecimiento    Establecimiento @relation(fields: [establecimiento_id], references: [id])
  campana            Campana?        @relation(fields: [campana_id], references: [id])
  movimientos        MovimientoStock[]
  
  @@map("silos")
  @@index([empresa_id])
  @@index([establecimiento_id])
}

model MovimientoStock {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fecha         DateTime  @db.Date
  tipo          String    // INGRESO, EGRESO
  empresa_id    String?   @db.Uuid
  empresa       Empresa?  @relation(fields: [empresa_id], references: [id])
  producto      String    // Soja, Maiz, Trigo
  cantidad      Decimal   @db.Decimal(12, 2)
  
  lote_id       String?   @db.Uuid
  silo_id       String?   @db.Uuid
  carta_porte_id String?  @db.Uuid // Future integration

  observaciones String?
  created_at    DateTime  @default(now()) @db.Timestamptz
  created_by    String?   @db.Uuid

  lote          Lote?     @relation(fields: [lote_id], references: [id])
  silo          Silo?     @relation(fields: [silo_id], references: [id])

  @@map("movimientos_stock")
  @@index([empresa_id])
  @@index([lote_id])
  @@index([silo_id])
}

model Lote {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre             String
  empresa_id         String?   @db.Uuid
  empresa            Empresa?  @relation(fields: [empresa_id], references: [id])
  hectareas          Decimal   @db.Decimal(10, 4) @default(0)
  establecimiento_id String    @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz
  deleted_at         DateTime? @db.Timestamptz

  establecimiento Establecimiento @relation(fields: [establecimiento_id], references: [id], onDelete: Cascade)
  ordenItems      OrdenItem[]
  movimientos     MovimientoStock[]
  
  @@map("lotes")
  @@index([empresa_id])
  @@index([establecimiento_id])
}

model Servicio {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre        String
  empresa_id    String?   @db.Uuid
  empresa       Empresa?  @relation(fields: [empresa_id], references: [id])
  unidad_medida String
  precio_base   Decimal  @db.Decimal(12, 2) @default(0)
  moneda        String?  @default("ARS") // ARS, USD
  created_at    DateTime @default(now()) @db.Timestamptz
  active        Boolean? @default(true)

  ordenItems OrdenItem[]
  presupuestoItems PresupuestoItem[]

  @@map("servicios")
}

model OrdenTrabajo {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fecha       DateTime    @default(dbgenerated("CURRENT_DATE")) @db.Date
  empresa_id  String?     @db.Uuid
  empresa     Empresa?    @relation(fields: [empresa_id], references: [id])
  cliente_id  String      @db.Uuid
  
  // Refactor: Moved specific fields to OrdenItem
  // kept total for caching/convenience
  total       Decimal     @db.Decimal(14, 2)
  moneda      String?     @default("ARS") // Global currency for the order

  estado      OrderStatus @default(pendiente)
  created_by  String?     @db.Uuid
  observaciones String?
  created_at  DateTime    @default(now()) @db.Timestamptz
  updated_at  DateTime    @default(now()) @db.Timestamptz

  cliente  Cliente   @relation(fields: [cliente_id], references: [id], onDelete: Restrict)
  items    OrdenItem[]
  factura  Factura?

  @@map("ordenes_trabajo")
  @@index([empresa_id])
  @@index([cliente_id])
  @@index([fecha])
  @@index([estado])
}

model OrdenItem {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orden_id      String   @db.Uuid
  orden         OrdenTrabajo @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  
  servicio_id   String   @db.Uuid
  servicio      Servicio @relation(fields: [servicio_id], references: [id], onDelete: Restrict)
  
  lote_id       String?  @db.Uuid // Optional: each item might be for a different lot? or keep global? keeping per item is flexible
  lote          Lote?    @relation(fields: [lote_id], references: [id])

  campana_id    String?  @db.Uuid
  campana       Campana? @relation(fields: [campana_id], references: [id])
  
  cantidad      Decimal  @db.Decimal(12, 4)
  kilometros    Decimal? @db.Decimal(12, 2)
  precio_unit   Decimal  @db.Decimal(12, 2)
  tipo_cambio   Decimal? @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(14, 2) // subtotal for this item

  observaciones String?
  insumos       OrdenItemInsumo[]

  @@map("orden_items")
}

model Factura {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orden_trabajo_id  String    @unique @db.Uuid
  tipo_comprobante  String
  empresa_id        String?   @db.Uuid
  empresa           Empresa?  @relation(fields: [empresa_id], references: [id])
  punto_venta       Int
  numero            BigInt
  cae               String?
  fecha_vencimiento DateTime? @db.Date
  total             Decimal   @db.Decimal(14, 2)
  fecha_emision     DateTime? @default(now()) @db.Timestamptz
  estado_afip       String?   @default("PENDIENTE")
  observaciones_afip String?
  pdf_url           String?
  created_at        DateTime  @default(now()) @db.Timestamptz

  orden OrdenTrabajo @relation(fields: [orden_trabajo_id], references: [id], onDelete: Restrict)

  @@map("facturas")
}

model Campana {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre        String
  empresa_id    String?   @db.Uuid
  empresa       Empresa?  @relation(fields: [empresa_id], references: [id])
  fecha_inicio  DateTime  @db.Date
  fecha_fin     DateTime  @db.Date
  activa        Boolean   @default(false)
  tipo          String?   @default("GENERAL") // GRUESA, FINA, GENERAL
  ciclo         String?   // 23/24, 24/25, etc.
  created_at    DateTime  @default(now()) @db.Timestamptz

  ordenItems    OrdenItem[]
  silos         Silo[]

  @@map("campanas")
}

model Presupuesto {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fecha       DateTime    @default(dbgenerated("CURRENT_DATE")) @db.Date
  empresa_id  String?     @db.Uuid
  empresa     Empresa?    @relation(fields: [empresa_id], references: [id])
  valido_hasta DateTime?  @db.Date
  cliente_id  String      @db.Uuid
  // Removed single service fields
  total       Decimal     @db.Decimal(14, 2)
  estado      String      @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  observaciones String?
  created_by  String?     @db.Uuid
  created_at  DateTime    @default(now()) @db.Timestamptz
  updated_at  DateTime    @default(now()) @db.Timestamptz

  cliente  Cliente   @relation(fields: [cliente_id], references: [id], onDelete: Restrict)
  items    PresupuestoItem[]

  @@map("presupuestos")
  @@index([empresa_id])
  @@index([cliente_id])
}

model PresupuestoItem {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  presupuesto_id String      @db.Uuid
  servicio_id    String      @db.Uuid
  cantidad       Decimal     @db.Decimal(12, 4)
  precio_unit    Decimal     @db.Decimal(12, 2)
  subtotal       Decimal     @db.Decimal(14, 2)
  detalle        String?

  presupuesto    Presupuesto @relation(fields: [presupuesto_id], references: [id], onDelete: Cascade)
  servicio       Servicio    @relation(fields: [servicio_id], references: [id], onDelete: Restrict)

  @@map("presupuesto_items")
}

model CartaPorte {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ctg             String?   // Código de Trazabilidad de Granos
  fecha_carga     DateTime  @default(now()) @db.Timestamptz
  empresa_id      String?   @db.Uuid
  empresa         Empresa?  @relation(fields: [empresa_id], references: [id])
  cliente_id      String    @db.Uuid
  origen          String
  destino         String
  remitente_comercial String?
  corredor        String?
  entregador      String?
  destinatario    String?
  chofer          String
  patente_camion  String
  patente_acoplado String?
  kilos_estimados Decimal   @db.Decimal(12, 2)
  peso_bruto      Decimal?  @db.Decimal(12, 2)
  peso_tara       Decimal?  @db.Decimal(12, 2)
  cuit_chofer     String?
  observaciones   String?
  estado          String    @default("EMITIDA") // BORRADOR, EMITIDA, ANULADA
  created_at      DateTime  @default(now()) @db.Timestamptz

  cliente Cliente @relation(fields: [cliente_id], references: [id], onDelete: Restrict)

  @@map("cartas_porte")
  @@index([empresa_id])
  @@index([cliente_id])
}

model Insumo {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre        String
  tipo          String    // semilla, fertilizante, herbicida, combustible, etc.
  unidad_medida String    // kg, litro, unidad
  empresa_id    String?   @db.Uuid
  empresa       Empresa?  @relation(fields: [empresa_id], references: [id])
  
  es_global     Boolean   @default(false)
  marca         String?
  proveedor     String?

  precios       PrecioInsumo[]
  ordenItems    OrdenItemInsumo[]
  
  created_at    DateTime  @default(now()) @db.Timestamptz
  active        Boolean   @default(true)

  @@map("insumos")
  @@index([empresa_id])
}

model PrecioInsumo {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  insumo_id   String   @db.Uuid
  insumo      Insumo   @relation(fields: [insumo_id], references: [id], onDelete: Cascade)
  
  precio      Decimal  @db.Decimal(12, 4) // precio por unidad_medida
  moneda      String   @default("USD")
  fecha_desde DateTime @default(now()) @db.Timestamptz
  fecha_hasta DateTime? @db.Timestamptz
  
  @@map("precios_insumos")
  @@index([insumo_id])
}

model OrdenItemInsumo {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orden_item_id   String   @db.Uuid
  orden_item      OrdenItem @relation(fields: [orden_item_id], references: [id], onDelete: Cascade)
  
  insumo_id       String   @db.Uuid
  insumo          Insumo   @relation(fields: [insumo_id], references: [id], onDelete: Restrict)
  
  dosis_por_ha    Decimal  @db.Decimal(12, 4)
  cantidad_pasadas Int     @default(1)
  
  // Snapshots for historical integrity
  precio_unit_usado Decimal @db.Decimal(12, 4) 
  moneda_usada      String  @default("USD")
  
  // Calculated fields (stored for reporting efficiency)
  costo_por_ha    Decimal  @db.Decimal(14, 2)
  costo_total     Decimal  @db.Decimal(14, 2)
  
  // Feature Avanzada: Interés
  interes_mensual Decimal? @db.Decimal(5, 2) // e.g. 2.5 for 2.5%
  meses_financiacion Int?
  costo_total_financiado Decimal? @db.Decimal(14, 2)
  
  created_at      DateTime @default(now()) @db.Timestamptz

  @@map("orden_item_insumos")
  @@index([orden_item_id])
  @@index([insumo_id])
}
