# Supabase Configuration
# Requerido tanto en Local como en Vercel
NEXT_PUBLIC_SUPABASE_URL="https://[TU-PROYECTO].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# Base de Datos (Prisma)
# Requerido tanto en Local como en Vercel (Generalmente connection pooling para serverless)
DATABASE_URL="postgresql://postgres.[TU-PROYECTO]:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.[TU-PROYECTO]:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require"

# Configuración de Servidor de Vercel / URL de la App
NEXT_PUBLIC_APP_URL="https://tu-dominio-en-vercel.vercel.app"

# API AFIP (Facturación Electrónica AFIP.js)
# IMPORTANTE PARA VERCEL: Como Vercel no despliega archivos fuera de /public con facilidad (para Serverless Functions),
# deberás cargar los certificados a una DB, AWS S3, o cambiar la lógica para leer base64 desde variables de entorno.
AFIP_CUIT="20123456789"
AFIP_CERT_PATH="./afip/cert.crt"
AFIP_KEY_PATH="./afip/key.key"
AFIP_PRODUCTION="false"
AFIP_PUNTO_VENTA="1"
